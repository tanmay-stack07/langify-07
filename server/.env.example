PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq — STT uses GROQ_API_KEY, translation uses GROQ_API_KEY_TRANSLATE (or falls back to primary)
GROQ_API_KEY=
GROQ_API_KEY_TRANSLATE=

# Google Cloud TTS (primary TTS — free tier 1M chars/month)
# Get key from: console.cloud.google.com → APIs & Services → Credentials
# If absent, falls back to Edge TTS automatically
GOOGLE_TTS_API_KEY=

# ElevenLabs HD Voice (optional premium TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5

# OpenAI (optional fallback STT only)
OPENAI_API_KEY=

# DAI Configuration
TRANSLATION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
DAI_ENABLED=true
VOCAB_MAX_ENTRIES=200
CONFIDENCE_THRESHOLD=0.72
